module mux4_8bit(
    input  logic [7:0] D0,
    input  logic [7:0] D1,
    input  logic [7:0] D2,
    input  logic [7:0] D3,
    input  logic [1:0] SEL,
    output logic [7:0] OUT
);

always_comb
case (SEL)
    2'b00: OUT = D0;
    2'b01: OUT = D1;
    2'b10: OUT = D2;
    2'b11: OUT = D3;
    default: OUT = 8'bxx;
endcase

endmodule
