timescale 1ns/100ps

module tb_decoder;

logic clk, reset;
logic [1:0] a;
logic [3:0] y, yexpected;

logic [31:0] vectornum, errors;
logic [5:0] testvectors [100:0];

decoder2_4 dut(a, y);

always begin
    clk = 1; #5; clk = 0; #5;
end

initial begin
    $readmemb("testcase_decoder.txt", testvectors);
    vectornum = 0;
    errors = 0;
    reset = 1; #27; reset = 0;
end

always @(posedge clk) begin
    #1; {a, yexpected} = testvectors[vectornum];
end

always @(negedge clk) begin
    if (~reset) begin
        if (y !== yexpected) begin
            errors = errors + 1;
        end

        vectornum = vectornum + 1;

        if (testvectors[vectornum] === 6'bx) begin
            $stop;
        end
    end
end

endmodule
